# ── 通义万相/文心一格 (Agent 2 绘图) ──
AI_DRAW_PROVIDER=alibaba
# 阿里云百炼 API Key（sk-ws-... 或 sk-...）
ALIBABA_API_KEY=
# 百度文心一格（备选）
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# ── 联网搜索 (Agent 1 动态生成文化数据) ──
# 必须：任意地名都可自动搜索生成 4×6 文化主题
# 免费注册: https://tavily.com/
SEARCH_PROVIDER=tavily
SEARCH_API_KEY=
# 可选：OpenAI API Key 可让 AI 更好地从搜索结果提炼文化元素
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-4o-mini
